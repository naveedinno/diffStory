{
  "name": "diffstory-vscode",
  "displayName": "DiffStory Navigation Bridge",
  "description": "Opens implementations and definitions from the DiffStory desktop and web review surface.",
  "version": "0.9.0",
  "publisher": "naveedinno",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/naveedinno/diffStory.git"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "diffstory",
    "navigation",
    "implementation",
    "definition"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onUri"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p .",
    "check": "npm run build && node --test test/*.test.mjs",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.98.0",
    "typescript": "^5.6.0"
  }
}
