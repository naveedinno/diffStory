{
  "name": "@naveedinno/diffstory",
  "version": "0.1.0",
  "description": "diffStory \u2014 the agent tells the story of its change: a guided, in-order diff review with a comment loop back to the agent.",
  "type": "module",
  "author": "naveedinno <naveedinno@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naveedinno/diffstory.git"
  },
  "homepage": "https://github.com/naveedinno/diffstory#readme",
  "bugs": "https://github.com/naveedinno/diffstory/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "assets/brand",
    "assets/demo",
    "scripts/setup-kokoro.sh",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:browser-assets",
    "build:browser-assets": "node scripts/build-browser-assets.mjs",
    "check": "npm run build && node --test test/*.test.mjs",
    "dev": "npm run build && node dist/app-server.js",
    "setup:kokoro": "sh scripts/setup-kokoro.sh",
    "start": "node dist/app-server.js",
    "demo": "npm run build && node examples/demo.mjs",
    "ui:atlas": "npm run build && node scripts/capture-ui-atlas.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "release:check": "npm run check && npm pack --dry-run --json",
    "prepublishOnly": "npm run check",
    "eval:stories": "npm run build && node scripts/eval-stories.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "diffstory",
    "code-review",
    "diff",
    "ai",
    "agent",
    "guided-review",
    "claude-code"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "mermaid": "^11.16.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.6.0"
  }
}
